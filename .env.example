PORT=8083
JDBC_DATABASE_URL=jdbc:postgresql://localhost:5432/bocra_db
JDBC_DATABASE_USERNAME=postgres
JDBC_DATABASE_PASSWORD=postgres
# Optional Railway URL variables (also supported)
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/bocra_db
# POSTGRES_URL=postgresql://postgres:postgres@localhost:5432/bocra_db
# Optional Railway DB variables (used automatically if JDBC_DATABASE_* are not set)
# PGHOST=localhost
# PGPORT=5432
# PGDATABASE=bocra_db
# PGUSER=postgres
# PGPASSWORD=postgres

APP_JWT_SECRET=replace-this-with-a-very-long-random-secret
APP_JWT_EXPIRATION_MS=3600000
APP_CORS_ALLOWED_ORIGINS=http://localhost:3000
APP_ADMIN_BOOTSTRAP_USERNAME=admin
APP_ADMIN_BOOTSTRAP_PASSWORD=Admin@12345

APP_AUTH_MAX_FAILED_ATTEMPTS=5
APP_AUTH_LOCK_MINUTES=15

APP_CAPTCHA_ENABLED=false
APP_CAPTCHA_SECRET=
APP_CAPTCHA_VERIFY_URL=https://challenges.cloudflare.com/turnstile/v0/siteverify

APP_RATE_LIMIT_ENABLED=true
APP_RATE_LIMIT_LOGIN_CAPACITY=5
APP_RATE_LIMIT_LOGIN_WINDOW_SECONDS=60
APP_RATE_LIMIT_PUBLIC_CAPACITY=20
APP_RATE_LIMIT_PUBLIC_WINDOW_SECONDS=300

APP_ENCRYPTION_ENABLED=true
APP_ENCRYPTION_SECRET=replace-this-with-a-strong-32-plus-char-secret
